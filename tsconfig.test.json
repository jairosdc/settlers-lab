{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "outDir": "dist-test",
    "rootDir": "src",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "noEmit": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "allowImportingTsExtensions": false
  },
  "include": [
    "src/engine/**/*.ts",
    "src/data/**/*.ts"
  ]
}